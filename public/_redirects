# Cloudflare Pages redirects.
# Preserves SEO and any external link still pointing at the old URLs
# after the renames:
#   Concerts      → News
#   Publications  → Stochastics
#   Works         → Listen
# 308 = permanent + preserves the request method.

/concerts        /news          308
/publications    /stochastics   308
/works           /listen        308
/works/*         /listen/:splat 308
